# =============================================================================
# Voice AI Agent — Environment Variables
# Copy this to .env and fill in your keys
# =============================================================================

# ── Cerebras LLM ─────────────────────────────────────────────────────────────
# Already have these — just paste in
CEREBRAS_API_KEY=your_cerebras_api_key_here
CEREBRAS_MODEL=gpt-oss-120b

# ── LiveKit Cloud ─────────────────────────────────────────────────────────────
# Sign up free at: https://cloud.livekit.io
# Create a project → copy URL, API Key, API Secret
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Groq (Whisper ASR) ──────────────────────────────────────────────────────────────
# Sign up free at: https://console.groq.com (generous free tier — no CC required)
# Console → API Keys → Create Key
GROQ_API_KEY=your_groq_api_key_here

# ── Cartesia ─────────────────────────────────────────────────────────────────
# Sign up free at: https://cartesia.ai (free trial tier)
# Dashboard → API Keys → Create Key
CARTESIA_API_KEY=your_cartesia_api_key_here
# Dashboard → Voices → pick a voice → copy Voice ID
CARTESIA_VOICE_ID=694f9389-aac1-45b6-b726-9d9369183238

# ── Notion ───────────────────────────────────────────────────────────────────
# Free at: https://www.notion.so/my-integrations → New Integration
# Then share a Notion page/database with the integration
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Open your Notion database → copy the ID from URL
# URL format: notion.so/{workspace}/{DATABASE_ID}?v=...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── App Settings ─────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# How many conversation turns to keep in short-term memory (per session)
MAX_SESSION_HISTORY=20

# LiveKit room settings
LIVEKIT_ROOM_NAME=voice-agent-room
AGENT_PARTICIPANT_IDENTITY=voice-agent-bot
